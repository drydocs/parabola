{
  "name": "@drydocs/parabola",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "TypeScript SDK for moving native USDC between Circle's Arc network and Stellar via CCTP V2",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drydocs/parabola.git"
  },
  "bugs": {
    "url": "https://github.com/drydocs/parabola/issues"
  },
  "homepage": "https://github.com/drydocs/parabola#readme",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.9.0",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify:addresses": "node scripts/verify-contract-addresses.mjs",
    "smoke": "node scripts/testnet-smoke.mjs"
  },
  "keywords": [
    "usdc",
    "cctp",
    "arc",
    "stellar",
    "circle",
    "cross-chain"
  ],
  "license": "MIT",
  "dependencies": {
    "@stellar/stellar-sdk": "^13.0.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
