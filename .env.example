# Used by the files in examples/. Fund both accounts via https://faucet.circle.com
# Not required to build, typecheck, or test the SDK itself -- unit tests mock all
# network and RPC calls.

# EVM private key for an Arc testnet account (0x-prefixed).
ARC_PRIVATE_KEY=

# Stellar secret key (S...) for a Stellar testnet account.
STELLAR_SECRET_KEY=
